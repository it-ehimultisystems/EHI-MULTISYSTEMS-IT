# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY: required for the app to talk
# to Supabase at all -- without these, src/lib/supabase.ts falls back to a
# dummy.supabase.co placeholder client, and every auth/data call (including
# login and password reset) fails with a DNS resolution error. Get these
# from Supabase Dashboard -> Project Settings -> API -> Project URL /
# anon public key. VITE_-prefixed so Vite bundles it client-side (these are
# meant to be public, same as any anon key); server/app.ts reads the same
# vars server-side for /api/config and its admin routes.
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"

# SUPABASE_SERVICE_ROLE_KEY: server-only (never VITE_-prefixed -- must not
# be bundled client-side). Used by server/app.ts for admin operations
# (staff creation/deactivation, rate limiting) that need to bypass RLS.
# Get this from the same Supabase API settings page -- keep it secret.
SUPABASE_SERVICE_ROLE_KEY="MY_SUPABASE_SERVICE_ROLE_KEY"

# PAYSTACK_SECRET_KEY / TERMII_API_KEY: optional -- only needed if you're
# testing payment (server/paystack.ts) or SMS (server/notifications.ts)
# integrations locally. Safe to leave unset otherwise.
PAYSTACK_SECRET_KEY="MY_PAYSTACK_SECRET_KEY"
TERMII_API_KEY="MY_TERMII_API_KEY"

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_SENTRY_DSN: Error monitoring (client + server both read this same
# var — see server/app.ts and src/main.tsx). Not a secret; Sentry DSNs
# are designed to be public. Get this from your Sentry project settings
# (Settings -> Projects -> [project] -> Client Keys (DSN)). If unset,
# error reporting is skipped entirely and nothing else is affected.
VITE_SENTRY_DSN="MY_SENTRY_DSN"

# QZ_CERTIFICATE / QZ_PRIVATE_KEY: server-only, optional -- only needed to
# enable silent (dialog-free) printing via QZ Tray (server/qz.ts,
# src/lib/qzPrint.ts). QZ Tray only skips its "allow this site to print?"
# prompt once requests are signed by a certificate it's been told to
# trust, so this is a one-time ops step per deployment, not something the
# app generates itself:
#   1. openssl req -x509 -newkey rsa:2048 -nodes -keyout qz-private-key.pem \
#        -out qz-certificate.pem -days 3650 -subj "/CN=EHI Multisystems"
#   2. Register qz-certificate.pem with QZ Tray (see qz.io docs -- either
#      bundle it as an "override" cert for a signed installer, or add it
#      to QZ Tray's trusted-certificates list on each terminal).
#   3. Set QZ_CERTIFICATE to the contents of qz-certificate.pem and
#      QZ_PRIVATE_KEY to the contents of qz-private-key.pem (keep the
#      private key secret -- never VITE_-prefixed, never bundled client-side).
# Left unset, /api/qz/cert and /api/qz/sign both 503, silent printing is
# unavailable, and every device falls back to the existing open-tab/download
# flow -- nothing else about the app is affected.
QZ_CERTIFICATE="MY_QZ_PUBLIC_CERTIFICATE_PEM"
QZ_PRIVATE_KEY="MY_QZ_PRIVATE_KEY_PEM"
